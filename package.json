{
  "name": "@popkid/sdk",
  "version": "1.0.0",
  "description": "Universal TypeScript SDK for the Popkid REST API. Supports Node.js, Browsers, and Edge runtimes.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "popkid",
    "api",
    "sdk",
    "typescript",
    "downloader",
    "ai",
    "deepseek",
    "groq",
    "image-processing"
  ],
  "author": "Popkid Dev",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
